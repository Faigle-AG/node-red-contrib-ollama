{
  "name": "@faigle/node-red-contrib-ollama",
  "version": "0.1.4",
  "description": "Ollama integration node for Node-Red",
  "keywords": [
    "node-red",
    "ollama",
    "ai"
  ],
  "private": false,
  "license": "MIT",
  "node-red": {
    "nodes": {
      "ollama": "src/ollama.js"
    }
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mocha": "^11.7.6",
    "node-red": "^5.0.1",
    "node-red-node-test-helper": "^0.3.6",
    "prettier": "^3.9.4"
  },
  "dependencies": {
    "@faigle/node-red-runtime-utils": "^0.4.2"
  },
  "workspaces": [
    "../../node-red-runtime/*"
  ],
  "scripts": {
    "prepare": "npx --yes husky",
    "test": "mocha \"test/**/*_spec.js\"",
    "format": "prettier --write \"**/*.{js,html,md}\"",
    "lint": "eslint \"**/*.{js,html}\""
  },
  "lint-staged": {
    "*.{js,html,md}": "prettier --write",
    "*.{js,html}": "eslint"
  }
}
